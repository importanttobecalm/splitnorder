<?xml version="1.0" encoding="UTF-8"?>
<!--
  Bu web.xml SADECE container-level <error-page> mapping'leri için.
  Bootstrap (DispatcherServlet, filter, listener kayıtları) hala
  WebAppInitializer.java üzerinden yapılıyor (ADR-04 ihlali değil).

  Burada yapılan iş: Tomcat'in default 404/500/405/413 sayfalarını
  bastırıp tüm hata kodlarını /error/show/{code} controller'ına
  yönlendirmek. Bu sayede static dosya 404, JSP render hatası,
  MaxUploadSize 413 gibi DispatcherServlet ÖNCESİ/SONRASI çıkan
  hatalar da merkezi olarak yakalanır.
-->
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <error-page>
        <error-code>400</error-code>
        <location>/error/show/400</location>
    </error-page>
    <error-page>
        <error-code>401</error-code>
        <location>/error/show/401</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/error/show/403</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/error/show/404</location>
    </error-page>
    <error-page>
        <error-code>405</error-code>
        <location>/error/show/405</location>
    </error-page>
    <error-page>
        <error-code>413</error-code>
        <location>/error/show/413</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error/show/500</location>
    </error-page>
    <error-page>
        <error-code>502</error-code>
        <location>/error/show/502</location>
    </error-page>
    <error-page>
        <error-code>503</error-code>
        <location>/error/show/503</location>
    </error-page>

    <!-- Tüm yakalanmamış exception'lar 500 sayfasına -->
    <error-page>
        <exception-type>java.lang.Throwable</exception-type>
        <location>/error/show/500</location>
    </error-page>

</web-app>
