# Bu dosya Oracle Compute VM'inde /etc/stemsep/secrets.env yoluna kopyalanır.
# chmod 600 zorunlu — şifre içerir, asla repo'ya gitmez.
#
# systemd EnvironmentFile= bu dosyayı okur, KEY=VALUE çiftlerini env var yapar.
# JVM startup'ta Spring Environment bunları system property gibi -D ile veriliyor
# olmasa bile env var üzerinden okur (uyumlu key formatıyla).
#
# Spring property → env var dönüşümü: nokta yerine alt çizgi, tümü büyük harf
#   mysql.password   → MYSQL_PASSWORD
#   mysql.user       → MYSQL_USER (overrride etmek istersen)

MYSQL_PASSWORD=BURAYA_SIFRE_GIR
